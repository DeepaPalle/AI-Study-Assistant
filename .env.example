# Rename this file to .env and fill in your key
# Get a free Gemini API key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Embedding model (runs locally via Hugging Face, no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Gemini chat model
# gemini-1.5-flash has been shut down by Google (as of 2026).
# gemini-2.5-flash is a solid, cheap, current default.
# For the newest/most capable option, use gemini-3.5-flash instead.
GEMINI_MODEL=gemini-2.5-flash

# Where ChromaDB stores its vector index on disk
CHROMA_PERSIST_DIR=chroma_db

# RAG chunking settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVER_K=4
